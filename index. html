let currentFilter = "all";
let currentSort = { key:"upside", dir:"desc" };
let searchTerm = "";
let riskMode = false;

function consensusOrder(v){
  if(v === "Buy") return 3;
  if(v === "Hold") return 2;
  if(v === "Sell") return 1;
  return 0;
}

function statusOrder(v){
  if(v.includes("Core")) return 3;
  if(v.includes("Review")) return 2;
  if(v.includes("Legacy")) return 1;
  return 0;
}

function getStatusClass(status){
  if(status.includes("Core")) return "core";
  if(status.includes("Review")) return "review";
  if(status.includes("Legacy")) return "legacy";
  return "core";
}

function getConsensusClass(c){
  if(c === "Buy") return "buy";
  if(c === "Hold") return "hold";
  return "sell";
}

function getSignal(h){
  if(h.upside >= 20 && h.consensus === "Buy" && h.status.includes("Core")) return {label:"STRONG BUY", cls:"signal-strong"};
  if(h.upside < 7 || h.status.includes("Legacy")) return {label:"WATCH", cls:"signal-watch"};
  if(h.consensus === "Sell") return {label:"RISK", cls:"signal-risk"};
  return {label:"HOLD", cls:"signal-neutral"};
}

function normaliseRows(data){
  const ranked = [...data].sort((a,b)=>b.upside-a.upside);
  return data.map(row => {
    const rank = ranked.findIndex(r => r.ticker === row.ticker) + 1;
    return {...row, rank, signal:getSignal(row)};
  });
}

function passesFilter(h){
  if(currentFilter === "all") return true;
  if(currentFilter === "core") return h.status.includes("Core");
  if(currentFilter === "review") return h.status.includes("Review") || h.status.includes("Legacy");
  if(currentFilter === "high-upside") return h.upside > 20;
  if(currentFilter === "buy") return h.consensus === "Buy";
  return true;
}

function passesSearch(h){
  const s = searchTerm.trim().toLowerCase();
  if(!s) return true;
  return [
    h.ticker,
    h.name,
    h.sector,
    h.consensus,
    h.status
  ].join(" ").toLowerCase().includes(s);
}

function compare(a,b,key,dir){
  let av = a[key];
  let bv = b[key];

  if(key === "consensus"){
    av = consensusOrder(av);
    bv = consensusOrder(bv);
  } else if(key === "status"){
    av = statusOrder(av);
    bv = statusOrder(bv);
  } else if(key === "signal"){
    av = a.signal.label;
    bv = b.signal.label;
  } else if(typeof av === "string"){
    av = av.toLowerCase();
    bv = bv.toLowerCase();
  }

  if(av < bv) return dir === "asc" ? -1 : 1;
  if(av > bv) return dir === "asc" ? 1 : -1;
  return 0;
}

function getVisibleData(){
  let rows = normaliseRows(portfolio)
    .filter(passesFilter)
    .filter(passesSearch);

  rows.sort((a,b)=>compare(a,b,currentSort.key,currentSort.dir));
  return rows;
}

function renderTickerTape(){
  const tape = document.getElementById("tickerTape");
  tape.innerHTML = normaliseRows(portfolio)
    .sort((a,b)=>a.rank-b.rank)
    .map(h => `
      <div class="ticker-item">
        <span class="ticker-symbol">${h.ticker}</span>
        <span>$${h.price.toFixed(2)}</span>
        <span class="${h.upside > 0 ? 'ticker-up' : h.upside < 0 ? 'ticker-down' : 'ticker-neutral'}">
          ${h.upside > 0 ? '+' : ''}${h.upside.toFixed(2)}%
        </span>
      </div>
    `).join("");
}

function renderSummary(){
  const rows = normaliseRows(portfolio);
  const total = rows.reduce((s,h)=>s+h.weight,0);
  const avgUpside = rows.reduce((s,h)=>s+h.upside,0)/rows.length;
  const buyCount = rows.filter(h=>h.consensus==="Buy").length;
  const reviewCount = rows.filter(h=>!h.status.includes("Core")).length;
  const strongCount = rows.filter(h=>h.signal.label==="STRONG BUY").length;
  const highConviction = rows.filter(h=>h.status.includes("Core")).length;

  const cells = [
    {label:"Holdings", value:rows.length, note:"Preferred names"},
    {label:"Model Weight", value:`${total.toFixed(2)}%`, note:"Current placeholder total"},
    {label:"Avg Upside", value:`${avgUpside.toFixed(2)}%`, note:"Across all holdings"},
    {label:"Consensus Buy", value:buyCount, note:"Names rated buy"},
    {label:"Strong Buy Signals", value:strongCount, note:"Upside + conviction"},
    {label:"Review / Legacy", value:reviewCount, note:`${highConviction} core conviction`}
  ];

  document.getElementById("summaryStrip").innerHTML = cells.map(c => `
    <div class="summary-cell">
      <div class="summary-label">${c.label}</div>
      <div class="summary-value">${c.value}</div>
      <div class="summary-note">${c.note}</div>
    </div>
  `).join("");
}

function renderTable(){
  const rows = getVisibleData();
  const body = document.getElementById("holdingsBody");

  body.innerHTML = rows.map(h => `
    <tr class="${riskMode && (h.status.includes('Legacy') || h.upside < 7) ? '' : ''}">
      <td>${h.rank}</td>
      <td class="ticker">${h.ticker}</td>
      <td class="company">${h.name}</td>
      <td class="muted">${h.sector}</td>
      <td class="right">${h.weight.toFixed(2)}%</td>
      <td class="right">$${h.price.toFixed(2)}</td>
      <td class="right">$${h.target.toFixed(2)}</td>
      <td class="right ${h.upside > 0 ? 'pos' : h.upside < 0 ? 'neg' : 'neu'}">${h.upside > 0 ? '+' : ''}${h.upside.toFixed(2)}%</td>
      <td><span class="badge ${getConsensusClass(h.consensus)}">${h.consensus}</span></td>
      <td class="right">${h.buy}</td>
      <td class="right">${h.hold}</td>
      <td class="right">${h.sell}</td>
      <td class="${h.signal.cls}">${h.signal.label}</td>
      <td><span class="badge ${getStatusClass(h.status)}">${h.status.includes('Core') ? 'CORE' : h.status.includes('Review') ? 'REVIEW' : 'LEGACY'}</span></td>
      <td class="muted">${h.lastUpdate}</td>
    </tr>
  `).join("");

  if(riskMode){
    Array.from(body.querySelectorAll("tr")).forEach((tr, idx) => {
      const item = rows[idx];
      const risk = item.status.includes("Legacy") || item.upside < 7 || item.consensus === "Sell";
      if(!risk) tr.classList.add("dimmed");
    });
  }
}

function renderTopOpportunities(){
  const top = normaliseRows(portfolio)
    .sort((a,b)=>b.upside-a.upside)
    .slice(0,5);

  document.getElementById("topOpportunities").innerHTML = top.map(h => `
    <div class="insight">
      <div class="insight-title">${h.rank}. ${h.ticker} — ${h.upside.toFixed(2)}% upside</div>
      <div class="insight-copy">
        Target $${h.target.toFixed(2)} vs price $${h.price.toFixed(2)}. 
        Consensus ${h.consensus}. 
        Signal: <span class="${h.signal.cls}">${h.signal.label}</span>.
      </div>
    </div>
  `).join("");
}

function renderRiskFlags(){
  const risks = normaliseRows(portfolio)
    .filter(h => h.upside < 7 || h.status.includes("Legacy") || h.status.includes("Review"))
    .sort((a,b)=>a.upside-b.upside);

  document.getElementById("riskFlags").innerHTML = risks.length ? risks.map(h => `
    <div class="insight">
      <div class="insight-title">${h.ticker} — ${h.status}</div>
      <div class="insight-copy">
        Upside ${h.upside.toFixed(2)}%, consensus ${h.consensus}, broker split ${h.buy}/${h.hold}/${h.sell}.
      </div>
    </div>
  `).join("") : `<div class="insight-copy">No immediate risk flags detected.</div>`;
}

function renderSnapshot(){
  const rows = normaliseRows(portfolio);
  const sectors = {};
  rows.forEach(h => {
    sectors[h.sector] = (sectors[h.sector] || 0) + h.weight;
  });
  const largestSector = Object.entries(sectors).sort((a,b)=>b[1]-a[1])[0];
  const avgTargetGap = rows.reduce((s,h)=>s+(h.target-h.price),0)/rows.length;
  const buyRatio = `${rows.filter(h=>h.consensus==="Buy").length}/${rows.length}`;
  const reviewNames = rows.filter(h=>!h.status.includes("Core")).map(h=>h.ticker).join(", ") || "None";

  document.getElementById("snapshotKpis").innerHTML = `
    <div class="kpi-row"><span class="label">Largest Sector</span><span class="value">${largestSector[0]}</span></div>
    <div class="kpi-row"><span class="label">Sector Weight</span><span class="value">${largestSector[1].toFixed(2)}%</span></div>
    <div class="kpi-row"><span class="label">Avg Target Gap</span><span class="value">$${avgTargetGap.toFixed(2)}</span></div>
    <div class="kpi-row"><span class="label">Buy Ratio</span><span class="value">${buyRatio}</span></div>
    <div class="kpi-row"><span class="label">Review Names</span><span class="value">${reviewNames}</span></div>
  `;
}

function renderHouseView(){
  document.getElementById("houseViewNotes").innerHTML = `
    <div class="insight">
      <div class="insight-title">Healthcare remains a core pillar</div>
      <div class="insight-copy">CSL, ResMed and Sonic anchor quality and defensive growth within the portfolio.</div>
    </div>
    <div class="insight">
      <div class="insight-title">Energy and cyclicals add offset</div>
      <div class="insight-copy">Woodside, Santos and select industrial/resource names give a balancing sleeve against growth-led exposures.</div>
    </div>
    <div class="insight">
      <div class="insight-title">Under-review positions are clearly separated</div>
      <div class="insight-copy">Domino’s and Bapcor are intentionally visible as monitored names rather than core conviction holdings.</div>
    </div>
    <div class="insight">
      <div class="insight-title">Next upgrade</div>
      <div class="insight-copy">Add target weights, live performance, valuation notes, and committee decisions such as Accumulate, Hold, Review or Exit.</div>
    </div>
  `;
}

function renderAll(){
  renderTickerTape();
  renderSummary();
  renderTable();
  renderTopOpportunities();
  renderRiskFlags();
  renderSnapshot();
  renderHouseView();
}

function updateClock(){
  const now = new Date();
  document.getElementById("clock").textContent =
    now.toLocaleDateString(undefined,{day:"2-digit",month:"short",year:"numeric"}) +
    "  " +
    now.toLocaleTimeString();
}

document.querySelectorAll(".filter-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    currentFilter = btn.dataset.filter;
    renderTable();
  });
});

document.querySelectorAll("th[data-sort]").forEach(th => {
  th.addEventListener("click", () => {
    const key = th.dataset.sort;
    if(currentSort.key === key){
      currentSort.dir = currentSort.dir === "asc" ? "desc" : "asc";
    } else {
      currentSort.key = key;
      currentSort.dir = key === "name" || key === "ticker" || key === "sector" ? "asc" : "desc";
    }
    renderTable();
  });
});

document.getElementById("searchInput").addEventListener("input", e => {
  searchTerm = e.target.value;
  renderTable();
});

document.getElementById("resetBtn").addEventListener("click", () => {
  currentFilter = "all";
  currentSort = { key:"upside", dir:"desc" };
  searchTerm = "";
  riskMode = false;
  document.getElementById("searchInput").value = "";
  document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
  document.querySelector('.filter-btn[data-filter="all"]').classList.add("active");
  renderAll();
});

document.getElementById("sortUpsideBtn").addEventListener("click", () => {
  currentSort = { key:"upside", dir:"desc" };
  renderTable();
});

document.getElementById("toggleRiskBtn").addEventListener("click", () => {
  riskMode = !riskMode;
  renderTable();
});

document.addEventListener("keydown", e => {
  if(e.key === "/"){
    e.preventDefault();
    document.getElementById("searchInput").focus();
  }
  if(e.key.toLowerCase() === "u"){
    currentSort = { key:"upside", dir:"desc" };
    renderTable();
  }
  if(e.key.toLowerCase() === "r"){
    riskMode = !riskMode;
    renderTable();
  }
});

updateClock();
setInterval(updateClock, 1000);
renderAll();
</script>
</body>
</html>