<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Adviser Terminal — Preferred Portfolio</title>
<style>
  :root{
    --bg:#0a0a0a;
    --panel:#111111;
    --panel2:#161616;
    --panel3:#1b1b1b;
    --border:#242424;
    --border-soft:#1d1d1d;
    --text:#e8e8e8;
    --muted:#9a9a9a;
    --muted2:#6f6f6f;

    --green:#00c853;
    --red:#ff5252;
    --amber:#ffb300;
    --blue:#3d7eff;
    --cyan:#00bcd4;
    --white:#f5f5f5;
  }

  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;
    background:var(--bg);
    color:var(--text);
    font-family:"SF Mono","Roboto Mono","Menlo","Monaco","Consolas","Liberation Mono","Courier New",monospace;
    -webkit-font-smoothing:antialiased;
    font-variant-numeric: tabular-nums;
  }

  .app{
    min-height:100vh;
    display:grid;
    grid-template-rows:auto auto auto 1fr;
  }

  .topbar{
    display:grid;
    grid-template-columns:auto 1fr auto auto auto;
    align-items:center;
    gap:14px;
    padding:10px 16px;
    border-bottom:1px solid var(--border);
    background:#0c0c0c;
  }

  .brand{
    font-size:18px;
    font-weight:700;
    letter-spacing:.03em;
    color:var(--white);
  }

  .brand span{
    color:var(--blue);
  }

  .search-wrap{
    display:flex;
    align-items:center;
    gap:10px;
    min-width:0;
  }

  .search{
    width:100%;
    max-width:420px;
    background:var(--panel);
    border:1px solid var(--border);
    color:var(--text);
    padding:9px 12px;
    outline:none;
    font:inherit;
  }

  .top-btn{
    border:1px solid var(--border);
    background:var(--panel);
    color:var(--text);
    padding:8px 10px;
    font:inherit;
    cursor:pointer;
  }

  .top-btn:hover,
  .filter-btn:hover,
  .toolbar-btn:hover{
    background:var(--panel3);
  }

  .clock{
    color:var(--muted);
    font-size:12px;
    white-space:nowrap;
  }

  .ticker-tape{
    display:flex;
    gap:18px;
    overflow:auto;
    padding:8px 16px;
    border-bottom:1px solid var(--border);
    background:#0d0d0d;
    scrollbar-width:none;
  }
  .ticker-tape::-webkit-scrollbar{display:none}

  .ticker-item{
    white-space:nowrap;
    font-size:12px;
    color:var(--muted);
  }

  .ticker-symbol{
    color:var(--text);
    margin-right:6px;
    font-weight:700;
  }

  .ticker-up{color:var(--green)}
  .ticker-down{color:var(--red)}
  .ticker-neutral{color:var(--muted)}

  .summary-strip{
    display:grid;
    grid-template-columns:repeat(6,1fr);
    gap:0;
    border-bottom:1px solid var(--border);
    border-top:1px solid var(--border-soft);
    background:#0f0f0f;
  }

  .summary-cell{
    padding:14px 16px 12px;
    border-right:1px solid var(--border);
    min-height:74px;
  }

  .summary-cell:last-child{border-right:none}

  .summary-label{
    color:var(--muted2);
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:.08em;
    margin-bottom:8px;
  }

  .summary-value{
    font-size:22px;
    font-weight:700;
    line-height:1;
    color:var(--white);
  }

  .summary-note{
    margin-top:6px;
    font-size:11px;
    color:var(--muted);
  }

  .main{
    display:grid;
    grid-template-columns:1fr 340px;
    min-height:0;
  }

  .left{
    min-width:0;
    border-right:1px solid var(--border);
    display:grid;
    grid-template-rows:auto 1fr;
  }

  .toolbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:14px;
    padding:10px 14px;
    border-bottom:1px solid var(--border);
    background:#101010;
    flex-wrap:wrap;
  }

  .toolbar-left,
  .toolbar-right{
    display:flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }

  .toolbar-title{
    font-size:12px;
    color:var(--muted);
    text-transform:uppercase;
    letter-spacing:.08em;
    margin-right:8px;
  }

  .filter-btn,
  .toolbar-btn{
    border:1px solid var(--border);
    background:var(--panel);
    color:var(--text);
    padding:7px 9px;
    font:inherit;
    font-size:12px;
    cursor:pointer;
  }

  .filter-btn.active{
    border-color:var(--blue);
    color:var(--white);
    background:#121826;
  }

  .table-wrap{
    overflow:auto;
    min-height:0;
  }

  table{
    width:100%;
    border-collapse:collapse;
    font-size:12.5px;
  }

  thead th{
    position:sticky;
    top:0;
    z-index:3;
    background:#111111;
    color:#8d8d8d;
    text-align:left;
    font-weight:700;
    text-transform:uppercase;
    font-size:11px;
    letter-spacing:.08em;
    padding:10px 10px;
    border-bottom:1px solid var(--border);
    cursor:pointer;
    user-select:none;
    white-space:nowrap;
  }

  thead th.right,
  tbody td.right{
    text-align:right;
  }

  tbody td{
    padding:9px 10px;
    border-bottom:1px solid var(--border-soft);
    vertical-align:middle;
    white-space:nowrap;
  }

  tbody tr:hover{
    background:#141414;
  }

  tbody tr.dimmed{
    opacity:.45;
  }

  .ticker{
    font-weight:700;
    color:var(--white);
  }

  .company{
    color:var(--text);
  }

  .muted{
    color:var(--muted);
  }

  .pos{color:var(--green)}
  .neg{color:var(--red)}
  .neu{color:var(--muted)}

  .badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width:54px;
    padding:3px 7px;
    border-radius:3px;
    font-size:11px;
    font-weight:700;
    line-height:1.2;
    border:1px solid transparent;
  }

  .buy{
    color:var(--green);
    background:rgba(0,200,83,.10);
    border-color:rgba(0,200,83,.18);
  }

  .hold{
    color:var(--amber);
    background:rgba(255,179,0,.10);
    border-color:rgba(255,179,0,.18);
  }

  .sell{
    color:var(--red);
    background:rgba(255,82,82,.10);
    border-color:rgba(255,82,82,.18);
  }

  .core{
    color:var(--blue);
    background:rgba(61,126,255,.10);
    border-color:rgba(61,126,255,.18);
  }

  .review{
    color:var(--amber);
    background:rgba(255,179,0,.10);
    border-color:rgba(255,179,0,.18);
  }

  .legacy{
    color:var(--red);
    background:rgba(255,82,82,.10);
    border-color:rgba(255,82,82,.18);
  }

  .signal-strong{
    color:var(--green);
    font-weight:700;
  }
  .signal-watch{
    color:var(--amber);
    font-weight:700;
  }
  .signal-risk{
    color:var(--red);
    font-weight:700;
  }
  .signal-neutral{
    color:var(--muted);
    font-weight:700;
  }

  .right-panel{
    background:#0f0f0f;
    min-height:0;
    overflow:auto;
  }

  .side-section{
    border-bottom:1px solid var(--border);
  }

  .side-head{
    padding:12px 14px;
    background:#101010;
    border-bottom:1px solid var(--border-soft);
    font-size:12px;
    color:var(--muted);
    text-transform:uppercase;
    letter-spacing:.08em;
  }

  .side-body{
    padding:12px 14px;
  }

  .insight{
    padding:10px 0;
    border-bottom:1px solid var(--border-soft);
  }

  .insight:last-child{border-bottom:none;padding-bottom:0}
  .insight:first-child{padding-top:0}

  .insight-title{
    font-size:12px;
    color:var(--white);
    margin-bottom:5px;
  }

  .insight-copy{
    color:var(--muted);
    font-size:11.5px;
    line-height:1.5;
  }

  .kpi-list{
    display:grid;
    gap:10px;
  }

  .kpi-row{
    display:flex;
    justify-content:space-between;
    gap:12px;
    font-size:12px;
  }

  .kpi-row .label{color:var(--muted)}
  .kpi-row .value{color:var(--white); font-weight:700}

  .footer-note{
    padding:10px 14px 14px;
    color:var(--muted2);
    font-size:10.5px;
    line-height:1.5;
  }

  .help{
    color:var(--muted2);
    font-size:11px;
  }

  @media (max-width:1200px){
    .main{grid-template-columns:1fr}
    .left{border-right:none}
    .summary-strip{grid-template-columns:repeat(3,1fr)}
  }

  @media (max-width:760px){
    .topbar{
      grid-template-columns:1fr;
      gap:10px;
    }
    .search{max-width:none}
    .summary-strip{grid-template-columns:repeat(2,1fr)}
  }
</style>
</head>
<body>
<div class="app">

  <div class="topbar">
    <div class="brand">ADVISER <span>TERMINAL</span></div>
    <div class="search-wrap">
      <input id="searchInput" class="search" type="text" placeholder="Search ticker, company, sector…  (/)" />
    </div>
    <button class="top-btn" id="sortUpsideBtn">Sort Upside [U]</button>
    <button class="top-btn" id="toggleRiskBtn">Risk View [R]</button>
    <div class="clock" id="clock"></div>
  </div>

  <div class="ticker-tape" id="tickerTape"></div>

  <div class="summary-strip" id="summaryStrip"></div>

  <div class="main">
    <div class="left">
      <div class="toolbar">
        <div class="toolbar-left">
          <div class="toolbar-title">Filters</div>
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="core">Core</button>
          <button class="filter-btn" data-filter="review">Review</button>
          <button class="filter-btn" data-filter="high-upside">Upside > 20%</button>
          <button class="filter-btn" data-filter="buy">Consensus Buy</button>
        </div>
        <div class="toolbar-right">
          <div class="help">Click headers to sort • / search • U upside • R risk</div>
          <button class="toolbar-btn" id="resetBtn">Reset View</button>
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th data-sort="rank">Rank</th>
              <th data-sort="ticker">Ticker</th>
              <th data-sort="name">Company</th>
              <th data-sort="sector">Sector</th>
              <th class="right" data-sort="weight">Weight</th>
              <th class="right" data-sort="price">Price</th>
              <th class="right" data-sort="target">Target</th>
              <th class="right" data-sort="upside">Upside</th>
              <th data-sort="consensus">Consensus</th>
              <th class="right" data-sort="buy">Buy</th>
              <th class="right" data-sort="hold">Hold</th>
              <th class="right" data-sort="sell">Sell</th>
              <th data-sort="signal">Signal</th>
              <th data-sort="status">Status</th>
              <th data-sort="lastUpdate">Updated</th>
            </tr>
          </thead>
          <tbody id="holdingsBody"></tbody>
        </table>
      </div>
    </div>

    <aside class="right-panel">
      <section class="side-section">
        <div class="side-head">Top Opportunities</div>
        <div class="side-body" id="topOpportunities"></div>
      </section>

      <section class="side-section">
        <div class="side-head">Risk Flags</div>
        <div class="side-body" id="riskFlags"></div>
      </section>

      <section class="side-section">
        <div class="side-head">Portfolio Snapshot</div>
        <div class="side-body">
          <div class="kpi-list" id="snapshotKpis"></div>
        </div>
      </section>

      <section class="side-section">
        <div class="side-head">House View Notes</div>
        <div class="side-body" id="houseViewNotes"></div>
      </section>

      <div class="footer-note">
        Internal preferred portfolio terminal. Bloomberg-inspired layout for adviser use.
        Target weights, live market feeds, performance history, and valuation notes can be layered in next.
      </div>
    </aside>
  </div>
</div>

